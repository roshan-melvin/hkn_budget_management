{
  "name": "hkn-budget-management-system",
  "version": "1.0.0",
  "description": "IEEE HKN Budget Management System - Full Stack Application",
  "main": "src/index.js",
  "scripts": {
    "dev": "concurrently \"npm run backend\" \"npm run client\"",
    "backend": "node src/index.js",
    "client": "npm --prefix public/client run dev",
    "admin": "node scripts/serve_admin.js",
    "build": "cd public/client && tsc && vite build",
    "install:client": "cd public/client && npm install",
    "docker:build": "docker build -t hkn-budget-system .",
    "docker:run": "docker-compose up",
    "docker:stop": "docker-compose down",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "budget",
    "management",
    "ieee",
    "hkn"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.0",
    "mime-types": "^3.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.15.3",
    "uuid": "^9.0.0"
  }
}